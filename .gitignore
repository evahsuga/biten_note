# Firebase設定ファイル（Phase 2で除外予定）
# js/firebase-config.js

# 環境変数ファイル
.env
.env.local
.env.production

# Firebase Admin SDK サービスアカウントキー（機密情報）
*-firebase-adminsdk-*.json

# Mac
.DS_Store

# Windows
Thumbs.db

# Node modules（巨大・再生成可能なため除外）
node_modules/
# package-lock.json は追跡する（複数管理体制で依存バージョンを固定・共有するため）

# ビルド出力
dist/
build/

# 生成物（構成図PDF等・HTMLから再生成できるため追跡しない）
*.pdf

# IDE設定
.vscode/settings.json
.idea/

# ログファイル
*.log
npm-debug.log*
