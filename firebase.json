{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "*.md",
      "*.rules",
      "firestore.indexes.json"
    ]
  },
  "functions": {
    "source": "functions"
  },
  "extensions": {
    "firestore-send-email": "firebase/firestore-send-email@0.2.5"
  }
}
